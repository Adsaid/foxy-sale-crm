generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  DEV
  DESIGNER
  SALES
}

enum Specialization {
  FRONTEND
  BACKEND
  FULLSTACK
  UX_UI
  UI
  UX
}

enum TechStack {
  DEV
  DESIGNER
}

enum AccountType {
  UPWORK
  LINKEDIN
}

enum AccountOperationalStatus {
  ACTIVE
  PAUSED
  SETUP
  WARMING
}

enum AccountWarmUpStage {
  PROFILE_FILLING
  EMAIL_WARMING
  DOCS_EMAIL_WARMING
  STABLE
}

enum AccountDesktopType {
  ADS_POWER
  ANY_DESK
  RIVNE_IP
  LUTSK_IP
  LVIV_IP
  DOLPHIN
  MODEM
}

enum CallType {
  HR
  TECH
  CLIENT
  PM
  CLIENT_TECH
}

enum CallStage {
  HR
  TECH
  CLIENT
  PM
  CLIENT_TECH
}

enum CallStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum CallOutcome {
  SUCCESS
  UNSUCCESSFUL
  PENDING
  CANCELLED
}

enum AccountStatus {
  APPROVED
  PENDING
}

enum TeamStatus {
  APPROVED
  PENDING
}

model User {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  firstName       String
  lastName        String
  email           String          @unique
  password        String
  role            Role
  teamId          String?         @db.ObjectId
  team            Team?           @relation(fields: [teamId], references: [id])
  /** Доступ до CRM: PENDING — лише після схвалення адміна (самореєстрація без запрошення). */
  accountStatus   AccountStatus   @default(APPROVED)
  specialization  Specialization?
  badgeBgColor    String?
  badgeTextColor  String?
  telegramChatId  String?
  technologyIds   String[]        @db.ObjectId
  technologies    Technology[]    @relation(fields: [technologyIds], references: [id])
  createdAt       DateTime        @default(now())
  accounts        Account[]
  callsAsdev      CallEvent[]     @relation("CallerDev")
  createdCalls           CallEvent[]           @relation("CreatedBySales")
  salesAccountReports    SalesAccountReport[]  @relation("SalesSubmittedReports")
  invitationsCreated     Invitation[]         @relation("InvitationCreatedBy")

  @@index([teamId, role])
}

model Invitation {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  code         String    @unique
  email        String
  role         Role
  teamId       String?   @db.ObjectId
  team         Team?     @relation(fields: [teamId], references: [id])
  createdById  String    @db.ObjectId
  createdBy    User      @relation("InvitationCreatedBy", fields: [createdById], references: [id])
  createdAt    DateTime  @default(now())
  usedAt       DateTime?
  usedByUserId String?   @db.ObjectId

  @@index([createdById])
  @@index([teamId, createdAt])
}

model SalesAccountReport {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt          DateTime @default(now())
  teamId             String?  @db.ObjectId
  team               Team?    @relation(fields: [teamId], references: [id])
  submittedById      String   @db.ObjectId
  submittedBy        User     @relation("SalesSubmittedReports", fields: [submittedById], references: [id])
  weekYear           Int
  weekNumber         Int
  weekStart          DateTime
  accountsSnapshot   Json
  telegramText       String?

  @@index([teamId, submittedById, createdAt])
  @@index([weekYear, weekNumber])
}

model Technology {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String    @unique
  stackAudience TechStack @default(DEV)
  userIds       String[]  @db.ObjectId
  users         User[]    @relation(fields: [userIds], references: [id])
}

model Account {
  id                  String                    @id @default(auto()) @map("_id") @db.ObjectId
  account             String
  type                AccountType
  profileLinks        String[]
  description         String?
  operationalStatus   AccountOperationalStatus?
  warmUpStage         AccountWarmUpStage?
  location            String?
  desktopType         AccountDesktopType?
  contactsCount       Int?
  profileViewsCount   Int?
  teamId              String?                   @db.ObjectId
  team                Team?                     @relation(fields: [teamId], references: [id])
  ownerId             String                    @db.ObjectId
  owner               User                      @relation(fields: [ownerId], references: [id])
  calls               CallEvent[]
  /** Дата створення акаунта на платформі (окремо від createdAt запису в CRM). */
  accountCreatedAt    DateTime?
  createdAt           DateTime                  @default(now())

  @@index([teamId, ownerId])
}

model CallEvent {
  id                   String       @id @default(auto()) @map("_id") @db.ObjectId
  teamId               String?      @db.ObjectId
  team                 Team?        @relation(fields: [teamId], references: [id])
  accountId            String       @db.ObjectId
  account              Account      @relation(fields: [accountId], references: [id])
  company              String
  interviewerName      String
  callType             CallType
  callStartedAt        DateTime
  callEndedAt          DateTime?
  callerId             String       @db.ObjectId
  caller               User         @relation("CallerDev", fields: [callerId], references: [id])
  createdById          String       @db.ObjectId
  createdBy            User         @relation("CreatedBySales", fields: [createdById], references: [id])
  status               CallStatus   @default(SCHEDULED)
  outcome              CallOutcome  @default(PENDING)
  devFeedback          String?
  movingToNextStage    Boolean      @default(false)
  nextStep             CallStage?
  nextStepDate         DateTime?
  expectedFeedbackDate DateTime?
  notes                String?
  salaryFrom           Int?
  salaryTo             Int?
  callLink             String?
  description          String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@index([teamId, createdById, callStartedAt])
  @@index([teamId, callerId, callStartedAt])
}

model CallSummary {
  id               String      @id @default(auto()) @map("_id") @db.ObjectId
  teamId           String?     @db.ObjectId
  team             Team?       @relation(fields: [teamId], references: [id])
  /** Без @unique: Mongo unique без sparse не дозволяє кілька null (видалення дзвінків). */
  callEventId      String?     @db.ObjectId
  company          String
  accountName      String
  accountType      AccountType
  callType         CallType
  callerFirstName  String
  callerLastName   String
  callerRole       Role?
  callerId         String?     @db.ObjectId
  interviewerName  String
  callStartedAt    DateTime
  callEndedAt      DateTime?
  status           CallStatus   @default(COMPLETED)
  outcome          CallOutcome
  devFeedback      String?
  movingToNextStage Boolean    @default(false)
  nextStep         CallStage?
  nextStepDate     DateTime?
  notes            String?
  createdById      String      @db.ObjectId
  isTransferred   Boolean     @default(false)
  transferredById String?     @db.ObjectId
  transferredAt   DateTime?
  transferredFromAt DateTime?
  transferredToAt   DateTime?
  transferredReason String?
  /** Масив записів переносу: з якого часу на який, хто, причина (хронологія). */
  transferHistory   Json?
  createdAt        DateTime    @default(now())

  @@index([teamId, callStartedAt])
  @@index([callEventId])
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  teamId    String?  @db.ObjectId
  team      Team?    @relation(fields: [teamId], references: [id])
  userId    String   @db.ObjectId
  type      String
  title     String
  message   String
  payload   Json?
  dedupeKey String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([teamId, userId, createdAt])
  @@index([dedupeKey])
}

model TelegramLinkToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Team {
  id                  String              @id @default(auto()) @map("_id") @db.ObjectId
  name                String
  status              TeamStatus          @default(APPROVED)
  createdByUserId     String?             @db.ObjectId
  createdByName       String?
  createdByEmail      String?
  approvedAt          DateTime?
  createdAt           DateTime            @default(now())
  users               User[]
  accounts            Account[]
  calls               CallEvent[]
  summaries           CallSummary[]
  salesAccountReports SalesAccountReport[]
  invitations         Invitation[]
  notifications       Notification[]
}
